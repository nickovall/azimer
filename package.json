{
  "name": "azimer-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gen:catalog": "tsx scripts/build-catalog.mts",
    "build:bot-bundle": "tsx scripts/build-bot-bundle.mts",
    "test:calculator": "tsx tests/scripts/calculator-edge-cases.mts",
    "typecheck": "tsc --noEmit",
    "deploy:bot": "tsx scripts/build-catalog.mts && tsx scripts/build-bot-bundle.mts && supabase functions deploy telegram-bot --no-verify-jwt",
    "predev": "tsx scripts/build-catalog.mts",
    "prebuild": "tsx scripts/build-catalog.mts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.106.1",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "supabase": "^2.104.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.94.0"
  }
}
