# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Auto-generated by scripts/build-catalog.mts (prebuild hook)
/lib/calculator/catalog.generated.ts

# Auto-generated by scripts/build-bot-bundle.mts (esbuild)
/supabase/functions/_shared/calculator.bundle.js

# opennext build artifacts
.open-next/

# supabase scratch
/supabase/.temp/

# Claude Code local tooling
/.claude/

# Playwright/audit screenshot artifacts (regenerable, audits reference paths only)
/output/
